{
	"ap": {
		"edges": [
			{
				"from": "{{ap_node_id}}",
				"labels": [
					"consist_of"
				],
				"to": "{{op_node_id}}"
			},
			{
				"from": "{{op_node_id}}",
				"labels": [
					"output"
				],
				"to": "{{file_obj_node_id}}"
			},
			{
				"from": "{{task_node_id}}",
				"labels": [
					"is_accomplished"
				],
				"to": "{{ap_node_id}}"
			},
			{
				"from": "{{user_node_id}}",
				"labels": [
					"request"
				],
				"to": "{{task_node_id}}"
			}
		],
		"nodes": [
			{
				"id": "{{user_node_id}}",
				"labels": [
					"User"
				]
			},
			{
				"id": "{{ap_node_id}}",
				"labels": [
					"Analytical_Pattern"
				],
				"properties": {
					"description": "Analytical Pattern to retrieve a list of datasets",
					"name": "Retrieve Datasets AP",
					"process": "cross_dataset_discovery",
					"startTime": "{{start_time}}"
				}
			},
			{
				"id": "{{op_node_id}}",
				"labels": [
					"Query_Operator",
					"CDD_Operator"
				],
				"properties": {
					"description": "Dataset search executed via Cross-Dataset Discovery",
					"k": {{k}},
					"name": "Cross-Dataset Discovery Operator",
					"query": "{{query}}",
					"startTime": "{{start_time}}"
				}
			},
			{
				"id": "{{file_obj_node_id}}",
				"labels": [
					"cr:FileObject"
				]
			},
			{
				"id": "{{task_node_id}}",
				"labels": [
					"Task"
				],
				"properties": {
					"description": "Task to find a dataset",
					"name": "Dataset Retrieval Task"
				}
			}
		]
	}
}